  "query": "SELECT DISTINCT g.id, g.name, g.display_name, g.description, g.discord_guild AS \"discord_guild: PgSnowflake<GuildId>\", g.created_at, g.updated_at\n               FROM games g \n               JOIN game_admins ga ON g.id = ga.game_id \n               WHERE ga.admin_id = $1 \n               ORDER BY g.display_name",
